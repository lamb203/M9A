{
    "task": [
        {
            "name": "局外演绎：无声综合征",
            "entry": "TheSyndromeOfSilence",
            "option": [
                "携带好旅伴",
                "难度选择",
                "配器选择",
                "作战策略"
            ],
            "group": [
                "standalone"
            ],
            "description": "<span style=\"color:darkgray;font-size:15px\">3.8版本开始支持从游戏主页面启动，3.7版本须手动到如下界面启动</span>![SOSMain](resource/announcement/images/SOSMain.png)<span style=\"color:darkgray;font-size:15px\">M9A不能检查是否处于自动战斗状态，请确定上一次使用的是自动战斗（3.7版本请自行提前编好编队）</span><br><span style=\"color:orange;font-size:15px\">⚠使用前请先至少手动打完第一层，更多详细说明请看文档</span>"
        }
    ],
    "option": {
        "携带好旅伴": {
            "type": "switch",
            "label": "携带好旅伴",
            "cases": [
                {
                    "name": "No",
                    "pipeline_override": {}
                },
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "SOSMainMenu": {
                            "next": [
                                "SOSWordlessWorkshop",
                                "[JumpBack]SOSConfirm",
                                "[JumpBack]SOSStart"
                            ]
                        }
                    }
                }
            ]
        },
