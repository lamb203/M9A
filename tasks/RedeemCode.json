{
    "task": [
        {
            "name": "使用兑换码",
            "entry": "redeem_code",
            "option": [
                "自定义兑换码"
            ],
            "group": [
                "daily"
            ],
            "description": "<span style=\"color:tomato;font-size:15px\">会根据当前账号自动跳过已使用过的兑换码</span>"
        }
    ],
    "option": {
        "自定义兑换码": {
            "type": "input",
            "inputs": [
                {
                    "name": "兑换码",
                    "default": "占位",
                    "pattern_msg": "多个兑换码间用空格、逗号或分号分开",
                    "pipeline_type": "string"
                }
            ],
            "pipeline_override": {
                "redeem_codeStart": {
                    "attach": {
                        "codes": "{兑换码}"
                    }
                }
            }
        }
    }
}
