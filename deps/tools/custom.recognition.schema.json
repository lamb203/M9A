{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "custom_recognition": {
            "enum": [
                "MultiRecognition",
                "ColorOCR",
                "ColorOCRWithFallback",
                "CheckStopping",
                "CandyPageRecord",
                "BankShop",
                "ActivityRe_releaseChapter",
                "SailingRecordSelectTarget",
                "SailingRecordBoatRecord",
                "FindFirstUnplayedStageByCheckmark",
                "CCBuyCard",
                "CCRemainMoney",
                "APPhaseGate",
                "LucidscapeStageSelect",
                "SOSSelectNode",
                "SOSSelectEncounterOptionList",
                "SOSSelectEncounterOptionFindSelected",
                "APMapAnalyze",
                "ATTrailAnalyze",
                "APCardFinder"
            ]
        }
    },
    "anyOf": [
        {
            "$ref": "#/$defs/MultiRecognition"
        },
        {
            "$ref": "#/$defs/ColorOCR"
        },
        {
            "$ref": "#/$defs/ColorOCRWithFallback"
        },
        {
            "$ref": "#/$defs/CheckStopping"
        },
        {
            "$ref": "#/$defs/CandyPageRecord"
        },
        {
            "$ref": "#/$defs/BankShop"
        },
        {
            "$ref": "#/$defs/ActivityRe_releaseChapter"
        },
        {
            "$ref": "#/$defs/SailingRecordSelectTarget"
        },
        {
            "$ref": "#/$defs/SailingRecordBoatRecord"
        },
        {
            "$ref": "#/$defs/FindFirstUnplayedStageByCheckmark"
        },
        {
            "$ref": "#/$defs/CCBuyCard"
        },
        {
            "$ref": "#/$defs/CCRemainMoney"
        },
        {
            "$ref": "#/$defs/APPhaseGate"
        },
        {
            "$ref": "#/$defs/LucidscapeStageSelect"
        },
        {
            "$ref": "#/$defs/SOSSelectNode"
        },
        {
            "$ref": "#/$defs/SOSSelectEncounterOptionList"
        },
        {
            "$ref": "#/$defs/SOSSelectEncounterOptionFindSelected"
        },
        {
            "$ref": "#/$defs/APMapAnalyze"
        },
        {
            "$ref": "#/$defs/ATTrailAnalyze"
        },
        {
            "$ref": "#/$defs/APCardFinder"
        }
    ],
    "$defs": {
        "RequiredParam": {
            "anyOf": [
                {
                    "required": [
                        "custom_recognition_param"
                    ]
                },
                {
                    "required": [
                        "custom_recognition_param_code"
                    ]
                }
            ]
        },
        "MultiRecognition": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_recognition": {
                    "const": "MultiRecognition"
                },
                "custom_recognition_param": {
                    "type": "object",
                    "properties": {
                        "nodes": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "description": "节点名称数组，按顺序对应 $0、$1、$2..."
                        },
                        "logic": {
                            "type": "object",
                            "properties": {
                                "type": {
                                    "type": "string",
                                    "enum": [
                                        "AND",
                                        "OR",
                                        "CUSTOM"
                                    ],
                                    "default": "AND",
                                    "description": "逻辑类型：AND(所有节点都识别成功)、OR(任意节点识别成功)、NOT(节点识别结果取反)、CUSTOM(使用自定义表达式)"
                                },
                                "expression": {
                                    "type": "string",
                                    "description": "自定义逻辑表达式，仅当type=CUSTOM时使用。支持$0、$1、$2引用nodes数组节点，{NodeName}引用其他节点，AND、OR、NOT运算符和括号分组"
                                }
                            },
                            "required": [
                                "type"
                            ],
                            "additionalProperties": false,
                            "description": "逻辑判断条件"
                        },
                        "return": {
                            "oneOf": [
                                {
                                    "type": "array",
                                    "items": {
                                        "type": "integer"
                                    },
                                    "minItems": 4,
                                    "maxItems": 4,
                                    "description": "固定坐标 [x, y, w, h]"
                                },
                                {
                                    "type": "string",
                                    "description": "基于识别结果计算ROI表达式。支持$0、$1、$2引用节点区域，{NodeName}引用其他节点区域，UNION、INTERSECTION、OFFSET等函数"
                                }
                            ],
                            "description": "返回的ROI区域"
                        }
                    },
                    "required": [
                        "nodes",
                        "return"
                    ],
                    "additionalProperties": false
                }
            }
        },
        "ColorOCR": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_recognition": {
                    "const": "ColorOCR"
                },
                "custom_recognition_param": {
                    "type": "object",
                    "properties": {
                        "target_color": {
                            "type": "array",
                            "items": {
                                "type": "integer",
                                "minimum": 0,
                                "maximum": 255
                            },
                            "minItems": 3,
                            "maxItems": 3,
                            "default": [
                                255,
                                255,
                                255
                            ],
                            "description": "目标颜色RGB值，默认 [255, 255, 255] (白色)"
                        },
                        "tolerance": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 255,
                            "default": 55,
                            "description": "颜色容差，默认55"
                        },
                        "recognition": {
                            "type": "string",
                            "description": "要运行的OCR识别节点名称"
                        }
                    },
                    "required": [
                        "recognition"
                    ],
                    "additionalProperties": false
                }
            }
        },
        "ColorOCRWithFallback": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_recognition": {
                    "const": "ColorOCRWithFallback"
                },
                "custom_recognition_param": {
                    "type": "object",
                    "properties": {
                        "target_color": {
                            "type": "array",
                            "items": {
                                "type": "integer",
                                "minimum": 0,
                                "maximum": 255
                            },
                            "minItems": 3,
                            "maxItems": 3,
                            "default": [
                                255,
                                255,
                                255
                            ],
                            "description": "目标颜色RGB值，默认 [255, 255, 255] (白色)"
                        },
                        "tolerance": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 255,
                            "default": 55,
                            "description": "颜色容差，默认55"
                        },
                        "recognition": {
                            "type": "string",
                            "description": "要运行的OCR识别节点名称"
                        }
                    },
                    "required": [
                        "recognition"
                    ],
                    "additionalProperties": false
                }
            }
        },
        "CheckStopping": {
            "properties": {
                "custom_recognition": {
                    "const": "CheckStopping",
                    "description": "检查任务是否即将停止"
                }
            }
        },
        "CandyPageRecord": {
            "properties": {
                "custom_recognition": {
                    "const": "CandyPageRecord",
                    "description": "记录糖果页面状态"
                }
            }
        },
        "BankShop": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_recognition": {
                    "const": "BankShop",
                    "description": "在8个商品内容中寻找结果"
                },
                "custom_recognition_param": {
                    "type": "object",
                    "properties": {
                        "expected": {
                            "type": "string",
                            "description": "商品名称"
                        },
                        "inverse": {
                            "type": "boolean",
                            "default": false,
                            "description": "是否反转，默认 false"
                        }
                    },
                    "required": [
                        "expected"
                    ],
                    "additionalProperties": false
                }
            }
        },
        "ActivityRe_releaseChapter": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_recognition": {
                    "const": "ActivityRe_releaseChapter",
                    "description": "识别复刻活动对应别名"
                },
                "custom_recognition_param": {
                    "type": "object",
                    "properties": {
                        "Re_release_name": {
                            "type": "string",
                            "description": "复刻活动别名"
                        }
                    },
                    "required": [
                        "Re_release_name"
                    ],
                    "additionalProperties": false
                }
            }
        },
        "SailingRecordSelectTarget": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_recognition": {
                    "const": "SailingRecordSelectTarget",
                    "description": "识别航海记录界面中的目标关卡"
                },
                "custom_recognition_param": {
                    "type": "object",
                    "properties": {
                        "level": {
                            "type": "integer",
                            "enum": [
                                0,
                                1
                            ],
                            "description": "0: 普通, 1: 困难"
                        }
                    },
                    "required": [
                        "level"
                    ],
                    "additionalProperties": false
                }
            }
        },
        "SailingRecordBoatRecord": {
            "properties": {
                "custom_recognition": {
                    "const": "SailingRecordBoatRecord",
                    "description": "识别选择船队界面中骰子的点数"
                }
            }
        },
        "FindFirstUnplayedStageByCheckmark": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_recognition": {
                    "const": "FindFirstUnplayedStageByCheckmark",
                    "description": "遍历定义的关卡列表，查找第一个未通关的关卡"
                },
                "custom_recognition_param": {
                    "type": "object",
                    "properties": {
                        "difficulty": {
                            "type": "string",
                            "enum": [
                                "Easy",
                                "Normal",
                                "Hard"
                            ],
                            "description": "难度选择"
                        },
                        "mode": {
                            "type": "string",
                            "enum": [
                                "Normal",
                                "Quickly"
                            ],
                            "description": "模式选择"
                        }
                    },
                    "required": [
                        "difficulty",
                        "mode"
                    ],
                    "additionalProperties": false
                }
            }
        },
        "CCBuyCard": {
            "properties": {
                "custom_recognition": {
                    "const": "CCBuyCard",
                    "description": "翻斗棋：识别可购买卡牌"
                }
            }
        },
        "CCRemainMoney": {
            "properties": {
                "custom_recognition": {
                    "const": "CCRemainMoney",
                    "description": "翻斗棋：识别剩余缪斯币"
                }
            }
        },
        "APPhaseGate": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_recognition": {
                    "const": "APPhaseGate",
                    "description": "活动推图三阶段（故事模式/小径/探索模式）闸门"
                },
                "custom_recognition_param": {
                    "type": "object",
                    "properties": {
                        "query": {
                            "type": "string",
                            "enum": [
                                "entry",
                                "story",
                                "trail",
                                "explore"
                            ]
                        }
                    },
                    "required": [
                        "query"
                    ],
                    "additionalProperties": false
                }
            }
        },
        "APMapAnalyze": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_recognition": {
                    "const": "APMapAnalyze",
                    "description": "活动自动推图地图分析"
                },
                "custom_recognition_param": {
                    "type": "object",
                    "properties": {
                        "query": {
                            "type": "string",
                            "enum": [
                                "stage",
                                "swipe",
                                "done"
                            ]
                        },
                        "difficulty_groups": {
                            "type": "integer",
                            "default": 3,
                            "description": "难度分组数"
                        },
                        "difficulty_lit_pixels": {
                            "type": "integer",
                            "default": 12,
                            "description": "单难度判过的亮像素数阈值"
                        },
                        "lit_pixels": {
                            "type": "integer",
                            "default": 15,
                            "description": "判定关卡已完成的亮像素数阈值"
                        },
                        "marker_b_max": {
                            "type": "integer",
                            "default": 95,
                            "description": "难度标记 B 通道上限"
                        },
                        "marker_extra_h": {
                            "type": "integer",
                            "default": 65,
                            "description": "难度标记搜索区相对编号框的下扩"
                        },
                        "marker_extra_w": {
                            "type": "integer",
                            "default": 25,
                            "description": "难度标记搜索区相对编号框的右扩"
                        },
                        "marker_g_max": {
                            "type": "integer",
                            "default": 150,
                            "description": "难度标记 G 通道上限"
                        },
                        "marker_g_min": {
                            "type": "integer",
                            "default": 45,
                            "description": "难度标记 G 通道下限"
                        },
                        "marker_pad_left": {
                            "type": "integer",
                            "default": 95,
                            "description": "难度标记搜索区相对编号框的左扩"
                        },
                        "marker_pad_top": {
                            "type": "integer",
                            "default": 10,
                            "description": "难度标记搜索区相对编号框的上扩"
                        },
                        "marker_rg_diff": {
                            "type": "integer",
                            "default": 25,
                            "description": "难度标记 R-G 差值下限"
                        },
                        "marker_r_min": {
                            "type": "integer",
                            "default": 120,
                            "description": "难度标记 R 通道下限"
                        },
                        "marker_s_min": {
                            "type": "integer",
                            "default": 80,
                            "description": "难度标记饱和度下限"
                        },
                        "multi_marker_pixels": {
                            "type": "integer",
                            "default": 30,
                            "description": "三难度红色标记像素数阈值"
                        },
                        "multi_star_width": {
                            "type": "integer",
                            "default": 180,
                            "description": "三难度星标行总宽"
                        },
                        "multi_zone_extra_w": {
                            "type": "integer",
                            "default": 240,
                            "description": "三难度星标搜索区右扩"
                        },
                        "right_empty_confirm": {
                            "type": "integer",
                            "default": 2,
                            "description": "右半屏无编号的连续确认帧数"
                        },
                        "right_half_x": {
                            "type": "integer",
                            "default": 640,
                            "description": "滑到头判定的右半屏分界 x"
                        },
                        "sat_min": {
                            "type": "integer",
                            "default": 100,
                            "description": "亮星像素饱和度下限（0-255）"
                        },
                        "stage_box_center_x_max": {
                            "type": "integer",
                            "default": 1240,
                            "description": "关卡编号框中心 x 上限"
                        },
                        "stage_box_center_x_min": {
                            "type": "integer",
                            "default": 120,
                            "description": "关卡编号框中心 x 下限"
                        },
                        "stage_box_center_y_max": {
                            "type": "integer",
                            "default": 620,
                            "description": "关卡编号框中心 y 上限"
                        },
                        "stage_box_center_y_min": {
                            "type": "integer",
                            "default": 535,
                            "description": "关卡编号框中心 y 下限"
                        },
                        "stage_box_h_max": {
                            "type": "integer",
                            "default": 55,
                            "description": "关卡编号框高度上限"
                        },
                        "stage_box_h_min": {
                            "type": "integer",
                            "default": 10,
                            "description": "关卡编号框高度下限"
                        },
                        "stage_num_max": {
                            "type": "integer",
                            "default": 30,
                            "description": "有效活动关卡编号上限，用于过滤星标/装饰 OCR 成 70/75/76 等不可能编号"
                        },
                        "stage_num_min": {
                            "type": "integer",
                            "default": 1,
                            "description": "有效活动关卡编号下限，用于过滤 OCR 装饰噪声 0"
                        },
                        "star_num_width_cap": {
                            "type": "integer",
                            "default": 62,
                            "description": "编号宽度参与星标行起点推算的上限"
                        },
                        "star_row_down": {
                            "type": "integer",
                            "default": 18,
                            "description": "三难度星标行相对编号框的下扩"
                        },
                        "star_row_up": {
                            "type": "integer",
                            "default": 35,
                            "description": "三难度星标行相对编号框的上扩"
                        },
                        "star_x0_backoff": {
                            "type": "integer",
                            "default": 8,
                            "description": "星标行起点回退量"
                        },
                        "star_x0_min_offset": {
                            "type": "integer",
                            "default": 25,
                            "description": "星标行起点最小偏移"
                        },
                        "val_min": {
                            "type": "integer",
                            "default": 160,
                            "description": "亮星像素亮度下限（0-255）"
                        },
                        "zero_stage_confirm": {
                            "type": "integer",
                            "default": 2,
                            "description": "亮星为 0 的关卡需连续确认帧数"
                        },
                        "zone_extra_h": {
                            "type": "integer",
                            "default": 20,
                            "description": "星标搜索区相对编号框的下扩"
                        },
                        "zone_extra_w": {
                            "type": "integer",
                            "default": 115,
                            "description": "星标搜索区相对编号框的右扩"
                        },
                        "zone_pad_left": {
                            "type": "integer",
                            "default": 5,
                            "description": "星标搜索区相对编号框的左扩"
                        },
                        "zone_pad_top": {
                            "type": "integer",
                            "default": 30,
                            "description": "星标搜索区相对编号框的上扩"
                        }
                    },
                    "required": [
                        "query"
                    ],
                    "additionalProperties": false
                }
            }
        },
        "ATTrailAnalyze": {
            "allOf": [
                {
                    "$ref": "#/$defs/RequiredParam"
                }
            ],
            "properties": {
                "custom_recognition": {
                    "const": "ATTrailAnalyze",
                    "description": "活动小径任务流程分析"
                },
                "custom_recognition_param": {
                    "type": "object",
                    "properties": {
                        "query": {
                            "type": "string",
                            "enum": [
                                "orange",
                                "reading",
                                "dialogue",
                                "task",
                                "done"
                            ]
                        },
                        "cream_s_max": {
                            "type": "integer",
                            "default": 60,
                            "description": "米白像素饱和度上限"
                        },
                        "cream_v_min": {
                            "type": "integer",
                            "default": 180,
                            "description": "米白像素亮度下限"
                        },
                        "dark_v_max": {
                            "type": "integer",
                            "default": 60,
                            "description": "暗像素亮度上限"
                        },
                        "dialog_click_box": {
                            "type": "array",
                            "items": {
                                "type": "integer"
                            },
                            "minItems": 4,
                            "maxItems": 4,
                            "default": [
                                1100,
                                620,
                                80,
                                40
                            ],
                            "description": "对话推进点击区 [x,y,w,h]（避开气泡的空白处）"
                        },
                        "dialog_confirm": {
                            "type": "integer",
                            "default": 2,
                            "description": "对话场景需连续确认帧数"
                        },
                        "dialog_dark_ratio": {
                            "type": "number",
                            "default": 0.75,
                            "description": "判定对话场景的暗像素占比阈值"
                        },
                        "dialog_stuck_limit": {
                            "type": "integer",
                            "default": 12,
                            "description": "对话画面连续不变多少次后停止点击"
                        },
                        "item_x_max": {
                            "type": "integer",
                            "default": 190,
                            "description": "小径任务项中心 x 上限"
                        },
                        "item_y_max": {
                            "type": "integer",
                            "default": 440,
                            "description": "小径任务项中心 y 上限"
                        },
                        "item_y_min": {
                            "type": "integer",
                            "default": 170,
                            "description": "小径任务项中心 y 下限"
                        },
                        "orange_b_max": {
                            "type": "integer",
                            "default": 100,
                            "description": "橙色像素 B 通道上限"
                        },
                        "orange_click_box": {
                            "type": "array",
                            "items": {
                                "type": "integer"
                            },
                            "minItems": 4,
                            "maxItems": 4,
                            "default": [
                                760,
                                318,
                                114,
                                49
                            ],
                            "description": "橙框点击区 [x,y,w,h]"
                        },
                        "orange_g_max": {
                            "type": "integer",
                            "default": 170,
                            "description": "橙色像素 G 通道上限"
                        },
                        "orange_g_min": {
                            "type": "integer",
                            "default": 80,
                            "description": "橙色像素 G 通道下限"
                        },
                        "orange_min_pixels": {
                            "type": "integer",
                            "default": 2000,
                            "description": "判定橙框存在的橙色像素数阈值"
                        },
                        "orange_roi": {
                            "type": "array",
                            "items": {
                                "type": "integer"
                            },
                            "minItems": 4,
                            "maxItems": 4,
                            "default": [
                                730,
                                295,
                                180,
                                100
                            ],
                            "description": "橙色交互框检测区 [x,y,w,h]"
                        },
                        "orange_r_min": {
                            "type": "integer",
                            "default": 180,
                            "description": "橙色像素 R 通道下限"
                        },
                        "orange_s_min": {
                            "type": "integer",
