{
    "AutoPromotion": {
        "desc": "活动推图入口：先手动进入活动关卡地图页再启动。按选项依次执行 故事模式推图 -> 小径 -> 探索模式推图，三阶段可独立开关",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "APPhaseGate",
                "custom_recognition_param": {
                    "query": "entry"
                }
            }
        },
        "next": [
            "AP_Navigate",
            "AP_StoryGate",
            "AT_TrailGate",
            "AP_ExploreGate",
            "AP_AllPhasesDone"
        ]
    },
    "AP_StoryGate": {
        "desc": "故事模式推图阶段闸门：enabled 由任务选项控制，本次任务已执行过则不再进入",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "APPhaseGate",
                "custom_recognition_param": {
                    "query": "story"
                }
            }
        },
        "next": [
            "AP_PromotionLoop"
        ]
    },
    "AP_ExploreGate": {
        "desc": "探索模式推图阶段闸门：先检查是否开放（活动后期才解锁），未开放则提示跳过；已开放则切换模式后推图",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "APPhaseGate",
                "custom_recognition_param": {
                    "query": "explore"
                }
            }
        },
        "next": [
            "AP_ExploreLocked",
            "AP_SwitchToExplore",
            "AP_PromotionLoop"
        ]
    },
    "AP_ExploreLocked": {
        "desc": "探索模式未开放：模式按钮下方有「X天X时后开启」倒计时。ROI 放宽覆盖不同活动的按钮区布局",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    60,
                    260,
                    300
                ],
                "expected": "后开启"
            }
        },
        "next": [
            "AP_AllPhasesDone"
        ],
        "focus": {
            "Node.Action.Starting": "<span style=\"color:orange\">探索模式尚未开放，跳过该阶段</span>"
        }
    },
    "AP_SwitchToExplore": {
        "desc": "点击左上角「探索模式」按钮切换（当期为单切换按钮；1987 等历史活动为故事/探索双按钮竖排，点击跟随 OCR 命中位置自适应）",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    20,
                    60,
                    220,
                    260
                ],
                "expected": "探索"
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 3000,
        "next": [
            "AP_PromotionLoop"
        ]
    },
    "AP_AllPhasesDone": {
        "desc": "所有已启用的阶段执行完毕，任务正常结束",
        "focus": {
            "Node.Action.Starting": "<span style=\"color:green\">活动推图任务完成（已启用的阶段均已执行）</span>"
        }
    },
    "AP_PromotionLoop": {
        "desc": "推图调度循环：在当前模式地图页自动推进直到无未完成关卡，与具体模式无关",
        "timeout": 60000,
        "next": [
            "CheckStopping",
            "AP_MiniGame",
            "AP_BossBalanceMode",
            "AP_BossChallengePage",
            "[JumpBack]AP_BossSettlement",
            "[JumpBack]AP_FlagInCombat",
            "[JumpBack]AP_CombatVictory",
            "AP_CombatDefeat",
            "[JumpBack]AP_InCombatRT",
            "[JumpBack]EatCandyPage",
            "[JumpBack]AP_SkipConfirm",
            "[JumpBack]AP_Skip",
            "AP_UnlockInsufficientCanister",
            "[JumpBack]AP_UnlockConfirm",
            "[JumpBack]Confirm",
            "[JumpBack]ObtainedAwards",
            "[JumpBack]ClickBlank",
            "[JumpBack]AP_UnlockStage",
            "[JumpBack]AP_StartAction",
            "[JumpBack]AP_EnterStage",
            "[JumpBack]AP_SwipeMap",
            "AP_AllDone"
        ],
        "on_error": [
            "AP_UnknownScreen"
        ]
    },
    "APExploreAnchorOCR": {
        "desc": "辅助节点：地图页左上角模式标签 OCR，作为地图页锚点（章节交界处无关卡编号时仍可识别），仅供 APMapAnalyze 内部调用，请勿加入 next。ROI 覆盖两种已知布局：单切换按钮+倒计时（当期，y≈88-131）与故事/探索双按钮竖排（1987 等历史活动，y≈153-280）",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    20,
                    60,
                    220,
                    260
                ],
                "expected": [
                    "探索",
                    "故事"
                ]
            }
        }
    },
    "APStageNumberOCR": {
        "desc": "辅助节点：地图底部条关卡编号 OCR，仅供 APMapAnalyze 内部调用，请勿加入 next",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    81,
                    538,
                    1130,
                    87
                ],
                "expected": "\\d"
            }
        }
    },
    "AP_EnterStage": {
        "desc": "地图页：找到编号最小的未完成关卡（编号旁灰色星标）并点击进入",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "APMapAnalyze",
                "custom_recognition_param": {
                    "query": "stage"
                }
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 1500
    },
    "AP_SwipeMap": {
        "desc": "地图页当前画面无未完成关卡时向后滑动翻页",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "APMapAnalyze",
                "custom_recognition_param": {
                    "query": "swipe"
                }
            }
        },
        "action": {
            "type": "Swipe",
            "param": {
                "begin": [
                    900,
                    586,
                    40,
                    20
                ],
                "end": [
                    340,
                    586,
                    40,
                    20
                ],
                "duration": 800
            }
        },
        "post_wait_freezes": {
            "time": 1000,
            "target": [
                230,
                500,
                1050,
                145
            ]
        },
        "post_delay": 1000
    },
    "AP_AllDone": {
        "desc": "地图滑到尽头且全部关卡完成，当前模式推图结束，继续后续阶段",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "APMapAnalyze",
                "custom_recognition_param": {
                    "query": "done"
                }
            }
        },
        "next": [
            "AT_TrailGate",
            "AP_ExploreGate",
            "AP_AllPhasesDone"
        ],
        "focus": {
            "Node.Action.Starting": "<span style=\"color:green\">当前地图推图完成，继续后续阶段</span>"
        }
    },
    "AP_InCombatRT": {
        "desc": "实时卡牌战斗中（左上角轮次/回合计数），等待游戏内自动战斗打完",
