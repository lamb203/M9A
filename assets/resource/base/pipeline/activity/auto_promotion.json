    "AP_UnlockStage": {
        "desc": "关卡详情页未解锁时点击「解锁」。成功后会回到可开始行动状态；失败会由 AP_UnlockInsufficientCanister 识别右上角「显影罐不足」提示并停止",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    1000,
                    560,
                    280,
                    160
                ],
                "expected": "解锁"
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 800
    },
    "AP_StartAction": {
        "desc": "编队页/关卡详情页的开始行动按钮。ROI 放宽覆盖不同活动的按钮位置（当期 y≈638-670，唐人街影话详情页 y≈612-640），点击跟随 OCR 命中位置",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    1000,
                    560,
                    280,
                    160
                ],
                "expected": "开始行动"
            }
        },
        "action": {
            "type": "Click"
        }
    },
