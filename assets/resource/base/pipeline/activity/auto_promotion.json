    "AP_UnlockInsufficientCanister": {
        "desc": "关卡解锁失败提示：点击解锁并确认后，右上角弹出「显影罐不足」时停止任务，避免继续误点或进入超时兜底",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    760,
                    20,
                    500,
                    130
                ],
                "expected": [
                    "显影罐不足",
                    "显影罐",
                    "不足"
                ]
            }
        },
        "focus": {
            "Node.Recognition.Succeeded": {
                "content": "关卡解锁失败：显影罐不足。请补足显影罐后重新运行活动推图。",
                "display": [
                    "log",
                    "toast"
                ]
            }
        }
    },
    "AP_UnlockConfirm": {
        "desc": "关卡解锁确认弹窗：点击「解锁」后出现时点确认",
