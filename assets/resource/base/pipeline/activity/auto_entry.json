{
    "APImagePageOCR": {
        "desc": "辅助节点：映像页顶部「显影罐」活跃奖励横幅 OCR，作为映像页锚点，仅供 APCardFinder 内部调用，请勿加入 next",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    200,
                    20,
                    500,
                    60
                ],
                "expected": "显影罐"
            }
        }
    },
    "APNavFullOCR": {
        "desc": "辅助节点：全屏 OCR（PV 播放判定用，PV 中几乎无 UI 文字），仅供 APCardFinder 内部调用，请勿加入 next",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    0,
                    1280,
                    720
                ],
                "expected": ".+"
            }
        }
    },
    "APCardTitleOCR": {
        "desc": "辅助节点：映像页卡片横排标题行 OCR，仅供 APCardFinder 内部调用，请勿加入 next",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    170,
                    1280,
                    60
                ],
                "expected": ".+"
            }
        }
    },
    "AP_Navigate": {
        "desc": "入口导航闸门：任务选项指定了目标活动时命中（card_name 为空或「当前页面」则跳过导航，沿用手动进入地图页的用法）",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "APCardFinder",
                "custom_recognition_param": {
                    "query": "nav",
                    "card_name": ""
                }
            }
        },
        "next": [
            "AP_NavLoop"
        ]
    },
    "AP_NavLoop": {
        "desc": "入口导航调度循环：主页「入场」-> 世纪末尺度页「映像」-> 卡片横排回卷到最左后逐屏查找 -> 点目标卡片 -> 详情页「活动正篇/主线正篇」-> 关卡地图页",
        "timeout": 60000,
        "on_error": [
            "AP_NavFailed"
        ],
        "next": [
            "CheckStopping",
            "[JumpBack]AP_NavStoryEnter",
            "AP_NavArrived",
            "[JumpBack]AP_NavCurrentEntry",
            "[JumpBack]AP_NavMainEntry",
            "[JumpBack]AP_NavMainEntryHigh",
            "[JumpBack]AP_NavMainEntryLow",
            "[JumpBack]AP_NavUnlockButton",
            "[JumpBack]Confirm",
            "AP_NavInsufficientCanister",
            "[JumpBack]AP_NavCardClick",
            "[JumpBack]AP_NavRewind",
            "[JumpBack]AP_NavForward",
            "AP_NavNotFound",
            "[JumpBack]AP_NavVideoTab",
            "[JumpBack]AP_NavEnterButton",
            "[JumpBack]AP_SkipConfirm",
            "[JumpBack]SkipButton",
            "[JumpBack]AP_NavPVTap",
            "[JumpBack]ReturnMain"
        ]
    },
    "AP_NavPVTap": {
        "desc": "首次进入卡片会播放 PV：点击屏幕中央唤出右上角跳过按钮（按钮出现后由公共 SkipButton 节点点击跳过）",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "APCardFinder",
                "custom_recognition_param": {
                    "query": "pv",
                    "card_name": ""
                }
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 1000
    },
    "AP_NavArrived": {
        "desc": "已到达关卡地图页（活动模式标签或主线编号条判定），导航完成，接入推图阶段链",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "APCardFinder",
                "custom_recognition_param": {
                    "query": "arrived",
                    "card_name": ""
                }
            }
        },
        "next": [
            "AP_StoryGate",
            "AT_TrailGate",
            "AP_ExploreGate",
            "AP_AllPhasesDone"
        ]
    },
    "AP_NavMainEntry": {
        "desc": "卡片详情页的「活动正篇/主线正篇」入口，第一档点击：上偏 40px（1987 等布局）。按钮热区高度随活动浮动，三档偏移依次重试（各 max_hit 2），到达地图页由 AP_NavArrived 判定退出导航",
        "max_hit": 2,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    300,
                    400,
                    980,
                    320
                ],
                "expected": [
                    "活动正篇",
                    "主线正篇"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    0,
                    -40,
                    0,
                    0
                ]
            }
        },
        "post_delay": 3000
    },
    "AP_NavMainEntryHigh": {
        "desc": "正篇入口第二档点击：上偏 73px（复兴！乌卢鲁运动会等按钮热区更高的布局）",
        "max_hit": 2,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    300,
                    400,
                    980,
                    320
                ],
                "expected": [
                    "活动正篇",
                    "主线正篇"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    0,
                    -73,
                    0,
                    0
                ]
            }
        },
        "post_delay": 3000
    },
    "AP_NavMainEntryLow": {
        "desc": "正篇入口第三档点击：上偏 13px（唐人街影话等小字上沿即热区的布局）",
        "max_hit": 2,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    300,
                    400,
                    980,
                    320
                ],
                "expected": [
                    "活动正篇",
                    "主线正篇"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    0,
                    -13,
                    0,
                    0
                ]
            }
        },
        "post_delay": 3000
    },
    "AP_NavCardClick": {
        "desc": "映像页找到目标卡片，点击进入详情页。点击前等画面静止：滑动动量未停时识别帧与点击时刻画面错位，会点中相邻卡片",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "APCardFinder",
                "custom_recognition_param": {
                    "query": "card",
                    "card_name": ""
                }
            }
        },
        "pre_wait_freezes": 500,
        "action": {
            "type": "Click"
        },
        "post_delay": 2500
    },
    "AP_NavRewind": {
        "desc": "映像页卡片横排先回卷到最左（右滑），保证查找从列表头开始",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "APCardFinder",
                "custom_recognition_param": {
                    "query": "rewind",
                    "card_name": ""
                }
            }
        },
        "action": {
            "type": "Swipe",
            "param": {
                "begin": [
                    200,
                    300,
                    40,
                    20
                ],
                "end": [
                    1150,
                    300,
                    40,
                    20
                ],
                "duration": 1200
            }
        },
        "post_delay": 1000
    },
    "AP_NavForward": {
        "desc": "映像页向右逐屏翻页查找目标卡片（左滑）。慢速短距滑动：快滑会触发惯性滚动跳过整屏卡片",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "APCardFinder",
                "custom_recognition_param": {
                    "query": "swipe",
                    "card_name": ""
                }
            }
        },
        "action": {
            "type": "Swipe",
            "param": {
                "begin": [
                    1000,
                    300,
                    40,
                    20
                ],
                "end": [
                    300,
                    300,
                    40,
                    20
                ],
                "duration": 1500
            }
        },
        "post_delay": 1200
    },
    "AP_NavNotFound": {
        "desc": "卡片列表扫完未找到目标活动，报错结束",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "APCardFinder",
                "custom_recognition_param": {
                    "query": "notfound",
                    "card_name": ""
                }
            }
        },
        "focus": {
            "Node.Action.Starting": {
                "content": "在映像页卡片列表中未找到所选活动，请确认活动名称或手动进入活动地图页后改用「当前页面」运行",
                "display": [
                    "log",
                    "toast"
                ]
            }
        }
    },
    "AP_NavVideoTab": {
        "desc": "世纪末尺度页底部菜单的「映像」标签（映像页内的查找/滑动节点优先级更高，不会重复点击）",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    100,
                    640,
                    300,
                    60
                ],
                "expected": "映像"
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 2000
    },
    "AP_NavCurrentEntry": {
        "desc": "「当期活动」专用（默认禁用，由选项启用）：主页点「入场」上方的版本名标题区（固定位置，文字每期变化故不依赖），进入当期活动入口界面。与 combat_activity.json 的 EnterTheActivityMain 同构（其点击位 [1103,220]，同一 banner 块），新版本入口若变可对照该节点",
        "enabled": false,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    900,
                    150,
                    380,
                    400
                ],
                "expected": "入场"
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    966,
                    226,
                    184,
                    42
                ]
            }
        },
        "post_delay": 3000
    },
    "AP_NavStoryEnter": {
        "desc": "「当期活动」专用（默认禁用，由选项启用）：活动入口界面点右侧「步入剧情」进入当期活动关卡地图。ROI 参考 cn.json FlagInActivityMain [1033,610,168,64]，收窄到右侧按钮区，避免 OCR 包围盒偏左导致点击失效",
        "enabled": false,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    903,
                    383,
                    351,
                    318
                ],
                "expected": [
                    "步入",
                    "剧情"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 3000
    },
    "AP_NavEnterButton": {
        "desc": "游戏主页活动 banner 的「入场」按钮，进入世纪末尺度页",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    900,
                    150,
                    380,
                    400
                ],
                "expected": "入场"
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 3000
    },
    "AP_NavInsufficientCanister": {
        "desc": "活动解锁失败：解锁→确认后，右上角 ROI [1067,105,112,32] 立即弹出「显影罐不足」，报错结束任务。非 JumpBack，命中即终止 AP_NavLoop；未弹出此提示则解锁成功，继续后续导航。优先级排在 Confirm 之后、AP_NavCardClick 之前",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    1067,
                    105,
                    112,
                    32
                ],
                "expected": ["不足"]
            }
        },
        "focus": {
            "Node.Action.Starting": {
                "content": "显影罐不足，无法解锁活动，任务结束。请补充显影罐后重试",
                "display": [
                    "log",
                    "toast"
                ]
            }
        }
    },
    "AP_NavUnlockButton": {
        "desc": "活动解锁弹窗第一步：点击卡片后若活动未解锁会弹出含「解锁」按钮的弹窗，OCR 找「解锁」并点击。流程：解锁→Confirm 点确认→AP_NavInsufficientCanister 判断显影罐是否充足。放在 Confirm/AP_NavCardClick 之前，避免背景卡片被反复误触卡死",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    900,
                    100,
                    380,
                    530
                ],
                "expected": "解锁"
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 800
    },
    "AP_NavFailed": {
        "desc": "导航超时兜底：报错结束（出错截图由框架 SaveOnError 自动保存到 debug/on_error）",
        "focus": {
            "Node.Action.Starting": {
                "content": "导航至所选活动失败（出错截图见 debug/on_error）。请手动进入活动关卡地图页后，将活动选项改为「当前页面」重新运行",
                "display": [
                    "log",
                    "toast"
                ]
            }
        }
    }
}
