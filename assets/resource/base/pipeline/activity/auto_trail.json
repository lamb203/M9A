{
    "AT_TrailGate": {
        "desc": "小径阶段闸门：enabled 由任务选项控制，本次任务已执行过则不再进入",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "APPhaseGate",
                "custom_recognition_param": {
                    "query": "trail"
                }
            }
        },
        "next": [
            "AutoTrail"
        ]
    },
    "AutoTrail": {
        "desc": "活动小径自动化调度循环：自动遍历地图左侧小径任务列表直至全部完成",
        "timeout": 60000,
        "on_error": [
            "AT_UnknownScreen"
        ],
        "next": [
            "CheckStopping",
            "[JumpBack]AT_OrangeBox",
            "[JumpBack]AT_ReadingPanel",
            "[JumpBack]AT_Dialogue",
            "[JumpBack]AT_PickTask",
            "AT_AllDone"
        ]
    },
    "ATTrailListOCR": {
        "desc": "辅助节点：地图页左侧小径列表 OCR，仅供 ATTrailAnalyze 内部调用，请勿加入 next",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    160,
                    190,
                    280
                ],
                "expected": ".+"
            }
        }
    },
    "AT_OrangeBox": {
        "desc": "任务点橙色交互框（倾听讨论/捡起它/完成等文案不定），统一点击",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "ATTrailAnalyze",
                "custom_recognition_param": {
                    "query": "orange"
                }
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 1500
    },
    "AT_ReadingPanel": {
        "desc": "阅读型任务的米白文本面板，点击面板外关闭即完成任务",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "ATTrailAnalyze",
                "custom_recognition_param": {
                    "query": "reading"
                }
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 1200
    },
    "AT_Dialogue": {
        "desc": "对话型任务的对话场景，空白处连点推进，推完游戏会自动退回地图",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "ATTrailAnalyze",
                "custom_recognition_param": {
                    "query": "dialogue"
                }
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 600
    },
    "AT_PickTask": {
        "desc": "地图页：点击小径列表最上面的任务，镜头会自动跳转到任务点",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "ATTrailAnalyze",
                "custom_recognition_param": {
                    "query": "task"
                }
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 2000
    },
    "AT_AllDone": {
        "desc": "小径列表已空（或仅剩未解锁任务），小径阶段完成，继续后续阶段",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "ATTrailAnalyze",
                "custom_recognition_param": {
                    "query": "done"
                }
            }
        },
        "focus": {
            "Node.Action.Starting": "<span style=\"color:green\">小径任务全部完成，继续后续阶段</span>"
        },
        "next": [
            "AP_ExploreGate",
            "AP_AllPhasesDone"
        ]
    },
    "AT_UnknownScreen": {
        "desc": "调度超时兜底：报错结束（出错截图由框架 SaveOnError 自动保存到 debug/on_error）",
        "focus": {
            "Node.Action.Starting": {
                "content": "小径任务遇到无法自动处理的界面，出错截图见 debug/on_error。请手动处理后回到活动地图页，重新运行本任务继续",
                "display": [
                    "log",
                    "toast"
                ]
            }
        }
    }
}
