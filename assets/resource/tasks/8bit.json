{
    "task": [
        {
            "name": "8-bit 街机秀",
            "entry": "8bit",
            "option": [
                "8-bit关卡难度",
                "8-bit刷取模式",
                "8-bit移动方式"
            ],
            "group": ["standalone"],
            "desc": "8-bit 街机秀刷代币，请到游戏主界面开始任务"
        }
    ],
    "option": {
        "8-bit关卡难度": {
            "type": "select",
            "label": "关卡难度",
            "cases": [
                {
                    "name": "单向投币Ⅰ",
                    "pipeline_override": {}
                },
                {
                    "name": "单向投币Ⅱ",
                    "pipeline_override": {
                        "8bitLevelSelect": {
                            "recognition": {
                                "param": {
                                    "roi": [
                                        459,
                                        169,
                                        94,
                                        26
                                    ]
                                }
                            }
                        }
                    }
                },
                {
                    "name": "单向投币Ⅲ",
                    "pipeline_override": {
                        "8bitLevelSelect": {
                            "recognition": {
                                "param": {
                                    "roi": [
                                        281,
                                        168,
                                        94,
                                        26
                                    ]
                                }
                            }
                        }
                    }
                }
            ]
        },
        "8-bit刷取模式": {
            "type": "select",
            "label": "刷取模式",
            "cases": [
                {
                    "name": "通关第一层后直接退出(稳定)",
                    "pipeline_override": {
                        "8bitFlagInCombat": {
                            "action": {
                                "type": "Custom",
                                "param": {
                                    "custom_action": "EightBitCombatInit",
                                    "custom_action_param": {
                                        "mode": "stable"
                                    }
                                }
                            }
                        }
                    }
                },
                {
                    "name": "尽力打",
                    "pipeline_override": {
                        "8bitCombatEnd": {
                            "next": [
                                "8bitFlagInCombat"
                            ]
                        },
                        "8bitFlagInCombat": {
                            "next": [
                                "8bitCombatEnd",
                                "8bitFlagInMain",
                                "[JumpBack]8bitHome",
                                "[JumpBack]Confirm",
                                "[JumpBack]8bitScoreRecord",
                                "[JumpBack]8bitCombatMove"
                            ]
                        }
                    }
                }
            ]
        },
        "8-bit移动方式": {
            "type": "select",
            "label": "移动方式",
            "description": "默认使用键盘方向键移动；如果进入移动界面后不动，可以切换为点击游戏界面的方式移动。",
            "cases": [
                {
                    "name": "键盘输入",
                    "pipeline_override": {}
                },
                {
                    "name": "点击输入",
                    "pipeline_override": {
                        "8bitCombatMove": {
                            "action": {
                                "param": {
                                    "custom_action_param": {
                                        "move_input": "click"
                                    }
                                }
                            }
                        }
                    }
                }
            ]
        }
    }
}
