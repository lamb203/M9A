{
    "task": [
        {
            "name": "局外演绎：黄昏的音序",
            "entry": "SeriesOfDusks",
            "option": [
                "触媒选择",
                "速刷模式",
                "演绎难度"
            ],
            "description": "<span style=\"color:darkgray;font-size:15px\">本功能有两种模式，触媒选择仅在非速刷模式生效，开启速刷模式后仅使用术式神灯刷取第一层</span><br><span style=\"color:black;font-size:18px\">速刷模式</span><br><span style=\"color:darkgray;font-size:15px\">1.使用前请先将`刻画生长-指引之歌`以及`刻画生长-建筑章程`点满</span><br><span style=\"color:darkgray;font-size:15px\">2.请尽量调高难度等级(11难度达到最高信用效率)以及点足科技树中信用效率加成，以防止分数不够2k5导致刷取信物失败</span><br><span style=\"color:black;font-size:18px\">非速刷模式</span><br><span style=\"color:darkgray;font-size:15px\">1.可在箱子里置顶(标记)四个角色出战</span><br><span style=\"color:darkgray;font-size:15px\">2.队伍推荐携带奶</span><br><span style=\"color:darkgray;font-size:15px\">3.M9A不能检查是否处于自动战斗状态，请自行调整</span><br><span style=\"color:orange;font-size:15px\">⚠更多详细说明请看文档</span>"
        }
    ],
    "option": {
        "触媒选择": {
            "type": "select",
            "label": "触媒选择",
            "cases": [
